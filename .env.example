# VI Number Scraper Environment Variables
# Copy this to .env and fill in your values

# VI Search Page Credentials (optional - search page is public)
SCRAPER_USERNAME=
SCRAPER_PASSWORD=

# Google Apps Script URL (required for Google Sheet sync)
GAS_URL=

# Server Configuration
PORT=7860
HEADLESS=true

# Worker Configuration (minimum 12, auto-scales up via autoRAM)
NUM_WORKERS=12
MAX_WORKERS=24
COOLDOWN_MINUTES=10
AUTO_START_WORKERS=true

# Browser Configuration
BROWSER_TIMEOUT=120000
NAVIGATION_TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# Security
SCRAPER_API_KEY=vi-scraper-secret-key-2024

# Form Defaults
SCRAPER_FULLNAME=Hankith
SCRAPER_MOBILE=9071977078
SCRAPER_PINCODE=560100

